# Environment Configuration
# Copy this file to .env and update values as needed

# Base URL for the application (used in playwright.config.js)
BASE_URL=https://demoqa.com

# Test Environment
TEST_ENV=local

# Browser configuration
BROWSER=chromium
HEADLESS=true

# Test timeouts (in milliseconds)
TIMEOUT=30000
EXPECT_TIMEOUT=10000
ACTION_TIMEOUT=10000
NAVIGATION_TIMEOUT=30000

# Parallel execution
WORKERS=3

# Screenshots and videos
SCREENSHOT_ON_FAILURE=only-on-failure
VIDEO_MODE=off

# Tracing
TRACE_MODE=on-first-retry

# Valid user credentials for testing
TEST_USERNAME=testuser
TEST_PASSWORD=Test@123
TEST_USER_EMAIL=testuser@example.com

# Invalid credentials for negative scenarios
INVALID_TEST_USERNAME=invaliduser
INVALID_TEST_PASSWORD=WrongPass@123

# API endpoints (if needed for future API testing)
API_BASE_URL=https://demoqa.com/api

# CI/CD configuration
CI=false